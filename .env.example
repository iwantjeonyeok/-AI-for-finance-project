# ===== LLM (보고서 종합 문장 생성용) =====
# 우선순위: LLM_PROVIDER=auto 이면 GEMINI_API_KEY → ANTHROPIC_API_KEY 순으로 자동 선택.
# 키가 하나도 없으면 실제 PDF 본문에서 상승/하락 문장을 추출하는 휴리스틱으로 동작(가짜 근거 X).
LLM_PROVIDER=auto

# Google Gemini (무료): https://aistudio.google.com 에서 발급
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude (유료): https://console.anthropic.com
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8

SEARCH_API_KEY=

# ===== 데이터베이스 =====
# 로컬 SQLite 기본값. PostgreSQL 예: postgresql+psycopg://user:pass@host:5432/db
DATABASE_URL=sqlite:///./bl_portfolio.db

# ===== 동작 모드 =====
# true 이면 외부 API 없이 fixture(가짜 샘플) 기반으로 전체 흐름 실행.
# false 이면 실제 국내 증권사 리서치(네이버 금융 리서치)와 실시간 시세를 사용한다.
DEMO_MODE=false

# ===== 실데이터 출처 (DEMO_MODE=false 일 때) =====
# 리서치: naver(네이버 금융 리서치, 국내 증권사 리포트 집계 · 공개) | web(Tavily 등)
RESEARCH_SOURCE=naver
# 시세: naver(네이버 금융, 기본 · KRX 차단 환경에서도 동작) | pykrx
MARKET_SOURCE=naver
# 본문(PDF)을 실제로 내려받아 평가할 최대 후보 수(지연 제한, 최신순)
REPORT_FETCH_LIMIT=8
# 참고: ANTHROPIC_API_KEY 가 없으면 목표주가/기관/날짜는 실제값을 쓰되,
#       종합 문장은 실제 보고서 '제목' 기반 사실 요약으로 대체된다(가짜 근거 생성 안 함).
#       키가 있으면 실제 PDF 본문을 LLM 이 읽고 핵심근거/위험/합의·이견을 종합한다.

# ===== 포트폴리오 / Black–Litterman 파라미터 =====
PORTFOLIO_HORIZON_MONTHS=3
TAU=0.05
RISK_AVERSION=2.5
MAX_ASSET_WEIGHT=0.40
REPORT_MAX_COUNT=5

# ===== 공분산 =====
COV_LOOKBACK_DAYS=252
USE_LEDOIT_WOLF=true

# ===== 네트워크 =====
HTTP_TIMEOUT_SECONDS=15
HTTP_MAX_RETRIES=2

# ===== 프론트엔드 =====
NEXT_PUBLIC_API_BASE=http://localhost:8000
